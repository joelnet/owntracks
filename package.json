{
  "name": "owntracks-journal",
  "version": "1.0.0",
  "description": "A self-hosted Node.js server that receives location data from the [OwnTracks](https://owntracks.org/) mobile app, detects visits to places, reverse geocodes them, and generates a personal location journal.",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-test-module-mocks --test",
    "report": "node scripts/report.js",
    "remote:pull": "./scripts/remote-pull.sh",
    "curl:home": "./scripts/curl-location.sh 34.0171 -117.9026",
    "curl:target": "./scripts/curl-location.sh 34.0297163 -117.9190439"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "yaml": "^2.8.3"
  },
  "nodemonConfig": {
    "ignore": ["data/**", "logs/**"]
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
